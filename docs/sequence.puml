@startuml
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam participantPadding 20
skinparam boxPadding 10

actor "客户端" as Client
participant "Gin框架" as Gin
participant "业务处理器" as Handler
participant "OneSignal API" as OneSignal

== 发送文本推送通知流程 ==

Client -> Gin: POST /api/v1/push/text
activate Gin

Gin -> Gin: 安全中间件检查\n(认证/限流/CORS)
Gin -> Gin: 解析并验证请求参数

Gin -> Handler: SendTextPushNotification(req)
activate Handler

Handler -> Handler: 构建推送内容\n设置定时发送

Handler -> OneSignal: 创建API客户端
activate OneSignal

Handler -> OneSignal: POST /notifications\n(推送请求)
OneSignal --> Handler: 返回响应结果
deactivate OneSignal

alt 发送成功
    Handler --> Gin: 返回成功响应
    Gin --> Client: 200 OK\n{"code":0,"msg":"success","data":{}}
else 发送失败
    Handler --> Gin: 返回错误响应
    Gin --> Client: 4xx/5xx\n{"code":1001,"msg":"推送失败"}
end

deactivate Handler
deactivate Gin

@enduml